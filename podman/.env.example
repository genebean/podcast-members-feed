# .env.example — copy to .env and fill in all values
#
# On NixOS (Path B), these are managed by sops-nix or agenix and passed
# via the environmentFile option in the NixOS module. Do not use this
# file on NixOS.
#
# On the Umbrel VPS path (Path A), fill this in and keep it out of
# version control. compose.yml references it via env_file.

# BTCPay webhook secret.
# Generate with: openssl rand -hex 32
# Must match the secret in BTCPay Store Settings > Webhooks.
BTCPAY_WEBHOOK_SECRET=

# Internal URL of the PodServer members RSS feed.
# Use the Umbrel's Tailscale IP — never a public address.
#   http://<umbrel-tailscale-ip>/podserver/feed/<feed-id>.xml
PODSERVER_FEED_URL=

# Public base URL for subscriber feed URLs and the /recover page.
FEED_BASE_URL=https://members.yourpodcast.com

# SQLite database path. The compose volume maps ./data here.
DATABASE_PATH=/var/lib/podcast-token-service/tokens.db

# Bearer token for /metrics and /admin/ endpoints.
# Generate with: openssl rand -hex 32
ADMIN_TOKEN=

# Optional: URL of a pre-recorded "subscription expired" audio clip.
# This episode is injected into the feed on first access after expiry.
# Host it anywhere publicly accessible (e.g. your regular podcast CDN).
# Leave blank to inject a text-only notification episode instead.
EXPIRED_AUDIO_URL=

# SMTP credentials for email delivery.
# Required if subscribers may not provide a Nostr npub.
# Leave blank only if you will require npub from all subscribers.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=members@yourpodcast.com

# Nostr private key for the service keypair.
# Generate a dedicated keypair — do NOT use your personal key.
# Generate with: nak keygen
# Accepts nsec bech32 or hex format.
NOSTR_PRIVATE_KEY=

# Used by podcast-members-manage cleanup command to call /admin/cleanup.
# Set to the same value as ADMIN_TOKEN above.
# Only needed when running the CLI directly; not used by the service itself.
SERVICE_URL=http://127.0.0.1:8765
