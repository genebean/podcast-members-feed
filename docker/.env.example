# .env.example — copy to .env and fill in all values
#
# On NixOS (Path B), these are managed by sops-nix or agenix and passed
# via the environmentFile option in the NixOS module. Do not use this file
# on NixOS.
#
# On the Umbrel VPS path (Path A), fill this in and keep it out of version
# control. The docker-compose.yml references it via env_file.

# BTCPay Server webhook secret.
# Generate with: openssl rand -hex 32
# Must match the secret configured in BTCPay > Store > Webhooks.
BTCPAY_WEBHOOK_SECRET=

# Internal URL of the PodServer members RSS feed.
# On Path A, use the Umbrel's Tailscale IP:
#   http://<umbrel-tailscale-ip>/podserver/feed/<feed-id>.xml
# On Path B, this is a localhost address.
PODSERVER_FEED_URL=

# Public base URL for constructing subscriber feed URLs.
# Must match the domain configured in nginx.
FEED_BASE_URL=https://members.yourpodcast.com

# SQLite database path. The docker-compose volume maps ./data here.
DATABASE_PATH=/var/lib/podcast-token-service/tokens.db

# SMTP credentials for subscriber email delivery.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=members@yourpodcast.com

# Nostr private key for the service keypair.
# Generate a dedicated keypair — do NOT use your personal key.
# Accept nsec (bech32) or hex format.
# Generate with: nak keygen  or any Nostr key tool.
NOSTR_PRIVATE_KEY=
